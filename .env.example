# Base64-encoded username:bcrypt_hash (generate with: bun server/gen-htpasswd.ts <username>)
SITE_PASSWD=
REMOTEX_SERVER_PORT=18890
HOST=127.0.0.1

# VNC target (the server dials it directly; the browser speaks RFB through the /vnc/ws proxy)
VNC_HOST=127.0.0.1
VNC_PORT=5901
VNC_PASSWORD=

# Optional: out-of-band display resize for VNC servers without SetDesktopSize
# support (macOS Screen Sharing). The server SSHes into this host (key auth)
# and runs the displaymode helper — compile tools/displaymode.swift on the
# target first: swiftc -O -o ~/.local/bin/displaymode tools/displaymode.swift
#DISPLAY_RESIZE_SSH=user@host
#DISPLAY_RESIZE_CMD=~/.local/bin/displaymode
