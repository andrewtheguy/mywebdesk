# Base64-encoded username:bcrypt_hash (generate with: bun server/gen-htpasswd.ts <username>)
SITE_PASSWD=
GUAC_SERVER_PORT=18890
HOST=127.0.0.1
GUACD_HOST=127.0.0.1
GUACD_PORT=24822
DEBUG_GUAC_PROXY=0

# Remote protocol: vnc (default) or rdp
REMOTE_PROTOCOL=vnc

# VNC target (used when REMOTE_PROTOCOL=vnc)
VNC_HOST=169.254.0.1
VNC_PORT=5901
VNC_PASSWORD=

# RDP target (used when REMOTE_PROTOCOL=rdp; credentials are the Unix login of the xrdp host)
RDP_HOST=169.254.0.1
RDP_PORT=3389
RDP_USERNAME=
RDP_PASSWORD=
