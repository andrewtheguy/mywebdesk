{
  "name": "guac-vnc",
  "private": true,
  "version": "0.0.22",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "vite",
    "dev:server": "bun --watch server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts"
  },
  "dependencies": {
    "@novnc/novnc": "1.7.0",
    "express": "^5.2.1",
    "react": "^19",
    "react-dom": "^19",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@types/bun": "^1.3.9",
    "@types/express": "^5.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "typescript": "~5.9",
    "vite": "^7.2.4"
  }
}
